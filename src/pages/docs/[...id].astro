---
import type { DocsEntry, MenuItem } from "@/types";
import EntryLayout from "@components/docs/EntryLayout.astro";
import CollectionLayout from "@components/docs/CollectionLayout.astro";
import { getEntries, getEntriesInGroup, getGroups } from "@lib/contentParser";
import { sortByTitle } from "@lib/sortFunctions";

export async function getStaticPaths() {
  const entries = (await getEntries("docs", sortByTitle)) as DocsEntry[];

  return entries.map((entry) => {
    // 1. Limpiamos el ID de la extensión .md para que Astro no se confunda
    const cleanId = entry.id.replace(/\.md$/, "");
    
    // 2. Identificamos si es una categoría (termina en -index)
    const isGroup = cleanId.endsWith("-index");
    
    // 3. Definimos la URL (parámetro id)
    // Si es grupo: "carpeta/-index" -> "carpeta"
    // Si es curso: "carpeta/nombre-curso" -> "carpeta/nombre-curso"
    const idParam = isGroup 
      ? cleanId.replace("/-index", "") 
      : cleanId;

    return {
      params: { id: idParam },
      props: { entry, isGroup },
    };
  });
}

const { entry, isGroup } = Astro.props;

// Extraemos el nombre de la carpeta para buscar sus archivos hijos
// Ejemplo: de "gestion-riesgo/-index" extraemos "gestion-riesgo"
const groupName = entry.id.includes('/') 
  ? entry.id.split('/')[0] 
  : entry.id.replace("-index", "").replace(".md", "");

// Si estamos en una categoría, cargamos todos sus cursos
const groupEntries = isGroup
  ? ((await getEntriesInGroup("docs", groupName, sortByTitle)) as DocsEntry[])
  : [];

// Configuración del menú lateral (Browser Menu)
const browserMenu: MenuItem[] = [];
const groups = (await getGroups("docs", sortByTitle)) as DocsEntry[];

await Promise.all(
  groups.map(async (group) => {
    const cleanGroupId = group.id.replace("/-index", "").replace(".md", "");
    const subEntries = (await getEntriesInGroup(
      "docs",
      cleanGroupId,
      sortByTitle
    )) as DocsEntry[];
    
    browserMenu.push({
      title: group.data.title,
      id: cleanGroupId,
      children: subEntries.map((subEntry) => ({
        title: subEntry.data.title,
        id: subEntry.id.replace(".md", ""),
        children: [],
      })),
    });
  })
);
---

{
  isGroup ? (
    <CollectionLayout collectionIndex={entry} entries={groupEntries} />
  ) : (
    <EntryLayout entry={entry} browserMenu={browserMenu} />
  )
}