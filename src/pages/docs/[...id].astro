---
import { getCollection } from 'astro:content';
import CollectionLayout from "@components/docs/CollectionLayout.astro";
import EntryLayout from "@components/docs/EntryLayout.astro";

export async function getStaticPaths() {
  const allEntries = await getCollection('docs');
  
  return allEntries.flatMap(entry => {
    // Quitamos la extensión y el -index
    const cleanId = entry.id.replace("/-index", "").replace(".md", "");

    return [
      { params: { id: cleanId }, props: { entry } },
      { params: { id: encodeURI(cleanId) }, props: { entry } },
      { params: { id: cleanId.toLowerCase() }, props: { entry } }
    ];
  });
}

const { entry } = Astro.props;
const isGroup = entry.id.includes("-index");

let groupEntries = [];
if (isGroup) {
  const allDocs = await getCollection('docs');
  const folderName = entry.id.split('/')[0];
  groupEntries = allDocs.filter(item => 
    item.id.startsWith(folderName) && !item.id.includes("-index")
  );
  groupEntries.sort((a, b) => (a.data.weight ?? 99) - (b.data.weight ?? 99));
}
---

{isGroup ? (
  <CollectionLayout collectionIndex={entry} entries={groupEntries} />
) : (
  <EntryLayout entry={entry} />
)}