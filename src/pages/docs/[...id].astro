---
import { getCollection } from 'astro:content';
import CollectionLayout from "@components/docs/CollectionLayout.astro";
import EntryLayout from "@components/docs/EntryLayout.astro";

export async function getStaticPaths() {
  const allEntries = await getCollection('docs');
  
  return allEntries.flatMap(entry => {
    // Si el archivo es un index, la ruta debe ser el nombre de la carpeta
    const isIndex = entry.id.endsWith('index.md') || entry.id.endsWith('index');
    const path = isIndex 
      ? entry.id.replace(/\/index$/, '').replace('index.md', '') 
      : entry.id.replace(/\.md$/, '');

    return [
      { params: { id: path || undefined }, props: { entry } },
      { params: { id: entry.id }, props: { entry } }
    ];
  });
}

const { entry } = Astro.props;
// Detectamos si es un índice (página de grupo)
const isGroup = entry.id.toLowerCase().includes("index");

let groupEntries = [];
if (isGroup) {
  const allDocs = await getCollection('docs');
  // Obtenemos el nombre de la carpeta (ej: gestion-del-riesgo...)
  const folderName = entry.id.split('/')[0];
  
  // Filtramos para mostrar los temas dentro de esa carpeta
  groupEntries = allDocs.filter(item => 
    item.id.startsWith(folderName) && !item.id.toLowerCase().includes("index")
  );
}
---

{isGroup ? (
  <CollectionLayout collectionIndex={entry} entries={groupEntries} />
) : (
  <EntryLayout entry={entry} />
)}