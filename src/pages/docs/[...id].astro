---
import type { DocsEntry, MenuItem } from "@/types";
import EntryLayout from "@components/docs/EntryLayout.astro";
import CollectionLayout from "@components/docs/CollectionLayout.astro";
import { getEntries, getEntriesInGroup, getGroups } from "@lib/contentParser";
import { sortByTitle } from "@lib/sortFunctions";

export async function getStaticPaths() {
  const entries = (await getEntries("docs", sortByTitle)) as DocsEntry[];

  return entries.flatMap((entry) => {
    const isGroup = entry.id.includes("-index");
    const baseId = isGroup ? entry.id.replace("/-index", "") : entry.id;

    // Generamos DOS rutas por cada entrada para máxima compatibilidad
    // 1. La ruta limpia (ej: "gestion-del-riesgo")
    // 2. La ruta con .md (ej: "gestion-del-riesgo.md") que es la que tus tarjetas están pidiendo
    return [
      { params: { id: baseId.replace(".md", "") }, props: { entry, isGroup } },
      { params: { id: baseId.endsWith(".md") ? baseId : `${baseId}.md` }, props: { entry, isGroup } }
    ];
  });
}

const { entry, isGroup } = Astro.props;

// Lógica para encontrar el nombre de la carpeta (Grupo)
// Esto asegura que el curso "Análisis de peligros..." encuentre a su padre "Gestión del riesgo"
const groupName = entry.id.includes('/') 
  ? entry.id.split('/')[0] 
  : entry.id.replace("-index", "").replace(".md", "");

const groupEntries = isGroup
  ? ((await getEntriesInGroup("docs", groupName, sortByTitle)) as DocsEntry[])
  : [];

// Construcción del menú lateral
const browserMenu: MenuItem[] = [];
const groups = (await getGroups("docs", sortByTitle)) as DocsEntry[];

await Promise.all(
  groups.map(async (group) => {
    const cleanGroupId = group.id.replace("/-index", "").replace(".md", "");
    const subEntries = (await getEntriesInGroup("docs", cleanGroupId, sortByTitle)) as DocsEntry[];
    
    browserMenu.push({
      title: group.data.title,
      id: cleanGroupId,
      children: subEntries.map((sub) => ({
        title: sub.data.title,
        id: sub.id.replace(".md", ""),
        children: [],
      })),
    });
  })
);
---

{
  isGroup ? (
    <CollectionLayout collectionIndex={entry} entries={groupEntries} />
  ) : (
    <EntryLayout entry={entry} browserMenu={browserMenu} />
  )
}