---
// Importación relativa para evitar el error de "Cannot find module"
import BaseLayout from "../layouts/BaseLayout.astro";

const categorias = [
  {
    id: "sig",
    titulo: "Sistemas de Información Geográfica",
    desc: "Software, análisis espacial y gestión de datos vectoriales.",
    color: "border-blue-500",
    icon: "📍"
  },
  {
    id: "tele",
    titulo: "Teledetección y Fotogrametría",
    desc: "Procesamiento de imágenes satelitales, drones y LiDAR.",
    color: "border-green-500",
    icon: "🛰️"
  },
  {
    id: "carto",
    titulo: "Cartografía y Geodesia",
    desc: "Sistemas de referencia, proyecciones y diseño de mapas.",
    color: "border-yellow-500",
    icon: "🗺️"
  }
];
---

<BaseLayout title="Biblioteca Digital de Geomática">
  <section class="container py-12">
    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold text-white mb-4">Bibliografía Especializada</h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Explora nuestra colección de más de 1,000 recursos digitales organizados por especialidad.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-24">
      {categorias.map((cat) => (
        <a href={`#${cat.id}`} class={`group relative overflow-hidden rounded-2xl border-2 ${cat.color} bg-slate-900/50 backdrop-blur-md transition-all hover:scale-105 p-8 text-center`}>
          <div class="text-7xl mb-6 group-hover:animate-bounce">
             {cat.icon}
          </div>
          <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-blue-400">{cat.titulo}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{cat.desc}</p>
        </a>
      ))}
    </div>

    <div class="space-y-24">
      {categorias.map((cat) => (
        <div id={cat.id} class="scroll-mt-24">
          <div class="flex items-center mb-8 border-b border-white/10 pb-4">
            <span class="text-4xl mr-4">{cat.icon}</span>
            <h2 class="text-3xl font-bold text-white">{cat.titulo}</h2>
          </div>
          
          <div class="glass rounded-xl overflow-hidden border border-white/5 bg-white/5 p-4">
             <p class="text-slate-400 italic">Próximamente se listarán los libros aquí...</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  html { scroll-behavior: smooth; }
  .glass {
    backdrop-filter: blur(10px);
  }
</style>