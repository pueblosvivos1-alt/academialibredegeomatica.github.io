---
import BaseLayout from "@components/base/BaseLayout.astro";
---

// Datos temporales para el diseño (luego los moveremos a JSON)
const categorias = [
  {
    id: "sig",
    titulo: "Sistemas de Información Geográfica",
    desc: "Software, análisis espacial y gestión de datos vectoriales.",
    color: "border-blue-500",
    icon: "📍"
  },
  {
    id: "tele",
    titulo: "Teledetección y Fotogrametría",
    desc: "Procesamiento de imágenes satelitales, drones y LiDAR.",
    color: "border-green-500",
    icon: "🛰️"
  },
  {
    id: "carto",
    titulo: "Cartografía y Geodesia",
    desc: "Sistemas de referencia, proyecciones y diseño de mapas.",
    color: "border-yellow-500",
    icon: "🗺️"
  }
];
---

<BaseLayout title="Biblioteca Digital de Geomática">
  <section class="container py-12">
    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold text-white mb-4">Bibliografía Especializada</h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Explora nuestra colección de más de 1,000 recursos digitales organizados por especialidad.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-24">
      {categorias.map((cat) => (
        <a href={`#${cat.id}`} class={`group relative overflow-hidden rounded-2xl border-2 ${cat.color} bg-slate-900/50 backdrop-blur-md transition-all hover:scale-105 p-8 text-center`}>
          <div class="text-7xl mb-6 group-hover:animate-bounce">
             {cat.icon}
          </div>
          <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-blue-400">{cat.titulo}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{cat.desc}</p>
          <div class="mt-6 inline-block text-blue-400 font-semibold text-sm">Ver listado completo ↓</div>
        </a>
      ))}
    </div>

    <div class="space-y-24">
      {categorias.map((cat) => (
        <div id={cat.id} class="scroll-mt-24">
          <div class="flex items-center mb-8 border-b border-white/10 pb-4">
            <span class="text-4xl mr-4">{cat.icon}</span>
            <h2 class="text-3xl font-bold text-white">{cat.titulo}</h2>
          </div>
          
          <div class="glass rounded-xl overflow-hidden border border-white/5">
            <div class="max-h-[600px] overflow-y-auto custom-scrollbar">
              <table class="w-full text-left border-collapse">
                <thead class="bg-white/5 text-slate-400 sticky top-0 backdrop-blur-md">
                  <tr>
                    <th class="p-4 font-semibold uppercase text-xs tracking-wider">Nombre del Libro / Recurso</th>
                    <th class="p-4 text-right font-semibold uppercase text-xs tracking-wider">Acceso</th>
                  </tr>
                </thead>
                <tbody class="text-slate-300 divide-y divide-white/5">
                  <tr class="hover:bg-white/5 transition-colors">
                    <td class="p-4 flex items-center">
                      <span class="text-blue-500 mr-3">📄</span>
                      Ejemplo de Manual de QGIS (Próximamente enlaces reales)
                    </td>
                    <td class="p-4 text-right">
                      <button class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-1 rounded text-sm transition">Descargar</button>
                    </td>
                  </tr>
                  {/* Aquí se inyectarán los 1,000 links automáticamente después */}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  html { scroll-behavior: smooth; }
  
  .custom-scrollbar::-webkit-scrollbar { width: 8px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.05); }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.2); border-radius: 10px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.3); }

  .glass {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
    backdrop-filter: blur(10px);
  }
</style>