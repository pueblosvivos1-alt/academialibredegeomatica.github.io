---
import BaseLayout from "@components/base/BaseLayout.astro";
import CourseCard from "./CourseCard.astro";

// Extraemos las propiedades que vienen desde [...id].astro
const { collectionIndex, entries } = Astro.props;

// BLOQUE DE SEGURIDAD
if (!collectionIndex || !collectionIndex.data) {
  return null; 
}

const { title, description } = collectionIndex.data;
---

<BaseLayout title={title} description={description}>
  <section class="py-12 bg-[#0f172a] min-h-screen">
    <div class="container mx-auto px-4">
      
      <div class="max-w-3xl mb-12">
        <nav class="mb-4">
          <a href="/docs" class="text-blue-400 hover:text-blue-300 text-sm flex items-center gap-2 transition-colors">
            ← Volver a Cursos
          </a>
        </nav>
        <h1 class="text-4xl font-bold text-white mb-4 tracking-tight">
          {title}
        </h1>
        {description && <p class="text-slate-400 text-lg leading-relaxed">{description}</p>}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
        {entries && entries.length > 0 ? (
          entries.map((course) => (
            /* Envolvemos en un div con h-full para asegurar que la tarjeta crezca */
            <div class="h-full">
              <CourseCard entry={course} />
            </div>
          ))
        ) : (
          <div class="col-span-full py-20 text-center border-2 border-dashed border-slate-800 rounded-3xl">
            <p class="text-slate-500 italic text-lg">
              Próximamente estaremos subiendo contenido para esta sección.
            </p>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>