---
import { getCollection } from 'astro:content';
const allDocs = await getCollection('docs');
const folders = allDocs ? [...new Set(allDocs.map(doc => doc.id.split('/')[0]))] : [];
---
<div class="bg-slate-900/50 rounded-xl p-4 border border-white/10">
  <ul class="space-y-2">
    {folders.map(folder => (
      <li>
        <details class="group">
          <summary class="text-slate-300 cursor-pointer list-none text-sm">📁 {folder}</summary>
          <ul class="ml-4 mt-2 space-y-1">
            {allDocs.filter(d => d.id.startsWith(folder) && !d.id.includes('-index')).map(d => (
              <li><a href={`/docs/${d.id.replace(/\.md$/, '')}`} class="text-slate-400 text-xs">📄 {d.data.title || d.id}</a></li>
            ))}
          </ul>
        </details>
      </li>
    ))}
  </ul>
</div>