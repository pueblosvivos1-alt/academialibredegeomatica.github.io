---
const { entry } = Astro.props;

// Datos seguros
const title = entry.data?.title || "Curso sin título";
const image = entry.data?.image;
const empresa = entry.data?.empresa || "CAEG";
const tipo = entry.data?.tipo || "Curso corto";
const botonTexto = entry.data?.botonTexto || "ACCESO";

// Convertir la imagen en una ruta utilizable
let imageSrc = "";
if (image) {
  imageSrc = typeof image === 'object' ? (image.src || "") : image;
}
---

<div class="h-full m-2 bg-[#0f172a] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl group transition-all duration-300 hover:border-blue-500/50">
  
  <div class="relative aspect-video bg-black overflow-hidden">
    {imageSrc && (
      <img 
        src={imageSrc} 
        alt={title} 
        class="object-cover w-full h-full opacity-80 group-hover:scale-105 transition-transform duration-500" 
      />
    )}
    
    <div class="absolute top-3 right-3 z-10">
      <span class="bg-[#facc15] text-black text-[10px] font-black px-3 py-1 rounded-full uppercase shadow-xl border border-yellow-600">
        {tipo}
      </span>
    </div>
  </div>

  <div class="p-5 flex flex-col flex-grow bg-gradient-to-b from-slate-900/50 to-[#0f172a]">
    <h3 class="text-white font-bold text-base mb-4 leading-tight">
      {title}
    </h3>

    <div class="mb-5 flex flex-col items-center border-l-4 border-blue-600 bg-blue-900/30 p-3 rounded-r-lg shadow-inner">
      <span class="text-[9px] text-blue-400 font-black uppercase tracking-widest mb-1">
        Certifica:
      </span>
      <span class="text-white text-sm font-bold">
        {empresa}
      </span>
    </div>

    <div class="mt-auto">
      <div class="w-full text-center bg-[#2563eb] text-white text-xs font-black py-3 rounded-xl border-b-4 border-blue-800 shadow-lg active:translate-y-1 active:border-b-0 transition-all">
        {botonTexto}
      </div>
    </div>
  </div>
</div>

<style>
  .h-full { min-height: 420px; }
</style>