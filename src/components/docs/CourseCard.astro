---
const { entry } = Astro.props;

// Seguridad: Si no hay datos, no dibujamos nada
if (!entry || !entry.data) return null;

// Extraemos los campos que definiste en tu Markdown
const { title, image, url_destino, botonTexto, tipo, empresa } = entry.data;

/**
 * 1. GENERACIÓN DE URL LIMPIA:
 * Quitamos el .md y el /index para que las rutas de las carpetas 
 * funcionen perfectamente sin errores 404.
 */
const urlInterna = `/docs/${entry.id
  .replace(/\.md$/, '')
  .replace(/\/index$/, '')
  .replace(/^index$/, '')}`;

/**
 * 2. LÓGICA DEL DESTINO:
 * Si en el MD pones 'url_destino', el botón te llevará a ese link (YouTube, Drive, etc).
 * Si no pones nada, te llevará a la página interna del curso.
 */
const destinoFinal = url_destino || urlInterna;
const esExterno = String(destinoFinal).startsWith('http');

/**
 * 3. LÓGICA DEL TEXTO DEL BOTÓN:
 * Por defecto siempre dirá "ACCESO".
 * Pero si en el MD escribes 'botonTexto: "DESCARGAR"', usará ese texto.
 */
const textoBoton = botonTexto || "ACCESO";
---

<div class="h-full bg-[#1e293b] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-xl transition-all hover:border-blue-500/50 group">
  
  <div class="relative aspect-video bg-slate-800 flex items-center justify-center p-2 overflow-hidden">
    
    {tipo && (
      <div class="absolute top-3 right-3 z-10 bg-emerald-500 text-white text-[9px] font-black px-2 py-1 rounded-md shadow-lg tracking-wider uppercase">
        {tipo}
      </div>
    )}

    {image ? (
      <img 
        src={image} 
        alt={title || "Miniatura"} 
        class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="text-slate-600 text-xs italic">Sin imagen</div>
    )}
  </div>

  <div class="p-5 flex flex-col flex-grow text-center">
    
    {empresa && (
      <span class="text-blue-400 text-[10px] font-black tracking-[0.2em] uppercase mb-2 block opacity-80">
        {empresa}
      </span>
    )}

    <h3 class="text-white font-bold text-sm mb-4 leading-tight min-h-[3rem] flex items-center justify-center">
      {title}
    </h3>

    <div class="mt-auto">
      <a 
        href={destinoFinal}
        target={esExterno ? "_blank" : "_self"}
        rel={esExterno ? "noopener noreferrer" : ""}
        class="block w-full text-center bg-[#2563eb] hover:bg-blue-500 text-white text-[10px] font-bold py-3 rounded-xl uppercase no-underline shadow-lg transition-all active:scale-95"
      >
        {textoBoton}
      </a>
    </div>
  </div>
</div>