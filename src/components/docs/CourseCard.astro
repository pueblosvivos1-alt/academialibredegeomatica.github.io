---
const { entry } = Astro.props;
if (!entry || !entry.data) return null;

const { title, image, url_destino, botonTexto } = entry.data;

// Usamos el 'slug' nativo de Astro para una URL siempre limpia
const urlInterna = `/docs/${entry.slug}`;
const destinoFinal = url_destino || urlInterna;
const esExterno = String(destinoFinal).startsWith('http');
---

<div class="h-full bg-[#1e293b] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-lg transition-transform hover:-translate-y-1">
  <div class="relative aspect-video bg-slate-800 flex items-center justify-center">
    {image ? (
      <img 
        src={image} 
        alt={title || "Curso CAEG"} 
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="text-slate-500 text-xs">Sin imagen</div>
    )}
  </div>
  
  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-white font-bold text-sm mb-4">{title}</h3>
    <div class="mt-auto">
      <a 
        href={destinoFinal} 
        target={esExterno ? "_blank" : "_self"}
        class="block w-full text-center bg-blue-600 hover:bg-blue-500 text-white text-[11px] font-bold py-3 rounded-lg uppercase transition-colors"
      >
        {url_destino ? "VER VIDEO" : (botonTexto || "ACCESO")}
      </a>
    </div>
  </div>
</div>