---
const { entry } = Astro.props;
if (!entry || !entry.data) return null;

const { title, image, url_destino, botonTexto, tipo, empresa } = entry.data;

// 1. Definimos las rutas
const urlInterna = `/docs/${entry.id.replace(/\.md$/, '').replace(/\/index$/, '').replace(/^index$/, '')}`;
const tieneDestino = url_destino && url_destino.trim().length > 0;
const enlaceFinal = tieneDestino ? url_destino.trim() : urlInterna;
const esExterno = enlaceFinal.startsWith('http');

// 2. Lógica de visualización
const esCategoria = entry.id.endsWith('index') || entry.id.endsWith('index.md');
const mostrarTipo = !esCategoria && tipo && tipo.trim().length > 1;
const mostrarEmpresa = !esCategoria && empresa && empresa.trim().length > 1;
---

<div class="h-full bg-[#1e293b] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-xl transition-all hover:border-blue-500/50 group relative">
  
  <div class="relative aspect-video bg-slate-800 flex items-center justify-center p-2 overflow-hidden">
    {mostrarTipo && (
      <div class="absolute top-3 right-3 z-20 bg-emerald-500 text-white text-[10px] font-black px-3 py-1.5 rounded-md shadow-lg tracking-wider uppercase">
        {tipo}
      </div>
    )}

    {image ? (
      <img src={image} alt={title} class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105" />
    ) : (
      <div class="text-slate-600 text-xs italic">Sin imagen</div>
    )}
  </div>

  <div class="p-5 flex flex-col flex-grow text-center">
    {mostrarEmpresa && (
      <span class="text-cyan-400 text-sm font-black tracking-[0.3em] uppercase mb-3 block drop-shadow-[0_0_8px_rgba(34,211,238,0.4)]">
        {empresa}
      </span>
    )}

    <h3 class="text-white font-bold text-base mb-4 leading-tight min-h-[3.5rem] flex items-center justify-center px-2">
      {title}
    </h3>

    <div class="mt-auto pt-2">
      <a 
        href={enlaceFinal} 
        target={esExterno ? "_blank" : "_self"}
        rel={esExterno ? "noopener noreferrer" : ""}
        class="relative z-30 block w-full text-center bg-[#2563eb] hover:bg-blue-400 text-white text-[11px] font-bold py-3.5 rounded-xl uppercase no-underline shadow-lg transition-all active:scale-95"
      >
        {botonTexto || "ACCESO"}
      </a>
    </div>
  </div>

  {!tieneDestino && (
    <a href={urlInterna} class="absolute inset-0 z-10" aria-label={title}></a>
  )}
</div>