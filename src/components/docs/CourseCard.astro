---
const { entry } = Astro.props;
if (!entry || !entry.data) return null;

const { title, image, url_destino, botonTexto } = entry.data;

// Generamos la ruta usando el ID exacto
const urlInterna = `/docs/${entry.id.replace(/\.md$/, '')}`;
const destinoFinal = url_destino || urlInterna;
const esExterno = String(destinoFinal).startsWith('http');
---

<div class="h-full bg-[#1e293b] border border-white/10 rounded-2xl overflow-hidden flex flex-col">
  <div class="relative aspect-video bg-slate-800 flex items-center justify-center">
    {image ? (
      <img 
        src={image} 
        alt={title || "Curso"} 
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="text-slate-500">Sin imagen</div>
    )}
  </div>
  
  <div class="p-4 flex flex-col flex-grow">
    <h3 class="text-white font-bold text-sm mb-4">{title}</h3>
    <div class="mt-auto">
      <a 
        href={destinoFinal} 
        target={esExterno ? "_blank" : "_self"}
        class="block w-full text-center bg-blue-600 text-white text-[10px] font-bold py-2 rounded-lg uppercase no-underline"
      >
        {url_destino ? "VER VIDEO" : (botonTexto || "ACCESO")}
      </a>
    </div>
  </div>
</div>