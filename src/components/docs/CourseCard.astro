---
const { entry } = Astro.props;

// Extracción segura de datos
const title = entry.data?.title || "Sin título";
const image = entry.data?.image;
const empresa = entry.data?.empresa || "CAEG";
const tipo = entry.data?.tipo || "Curso corto";
const botonTexto = entry.data?.botonTexto || "ACCESO";

// Preparar la ruta de la imagen (manejando si es objeto o string)
const imageSrc = image ? (typeof image === 'object' ? image.src : image) : null;
---

<div class="h-full m-2 bg-[#0f172a] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl group transition-all duration-300 hover:border-blue-500/40">
  
  <div class="relative aspect-video bg-black overflow-hidden">
    {imageSrc && (
      <img 
        src={imageSrc} 
        alt={title} 
        class="object-cover w-full h-full opacity-80 group-hover:scale-105 transition-transform duration-500" 
      />
    )}
    
    <div class="absolute top-3 right-3 z-10">
      <span class="bg-[#facc15] text-black text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-wider shadow-xl border border-yellow-600">
        {tipo}
      </span>
    </div>
  </div>

  <div class="p-5 flex flex-col flex-grow bg-gradient-to-b from-slate-900/50 to-[#0f172a]">
    <h3 class="text-white font-bold text-base mb-4 leading-tight group-hover:text-blue-400 transition-colors">
      {title}
    </h3>

    <div class="mb-5 flex flex-col items-center border-l-4 border-blue-600 bg-blue-900/20 p-3 rounded-r-lg shadow-inner">
      <span class="text-[9px] text-blue-400 font-black uppercase tracking-[0.1em] mb-1">
        Certifica:
      </span>
      <span class="text-white text-sm font-bold">
        {empresa}
      </span>
    </div>

    <div class="mt-auto">
      <div class="w-full text-center bg-[#2563eb] hover:bg-blue-500 text-white text-xs font-black py-3 rounded-xl border-b-4 border-blue-800 shadow-lg transition-all active:translate-y-1 active:border-b-0">
        {botonTexto}
      </div>
    </div>
  </div>
</div>

<style>
  /* Altura mínima para que todas las tarjetas se vean parejas */
  .h-full {
    min-height: 420px;
  }
</style>