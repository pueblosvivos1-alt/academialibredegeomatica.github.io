---
const { entry } = Astro.props;
if (!entry || !entry.data) return null;

const { title, image, url_destino, botonTexto } = entry.data;
const urlInterna = `/docs/${entry.id.replace(/\.md$/, '')}`;
const destinoFinal = url_destino || urlInterna;
const esExterno = String(destinoFinal).startsWith('http');
---

<div class="h-full bg-[#0f172a] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl">
  <div class="relative aspect-video bg-slate-800 flex items-center justify-center p-2">
    {image ? (
      <img src={image} alt={title || "Imagen"} class="object-contain w-full h-full" />
    ) : (
      <div class="text-slate-500 text-xs">Sin imagen</div>
    )}
  </div>
  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-white font-bold text-base mb-4 leading-tight">{title}</h3>
    <div class="mt-auto">
      <a href={destinoFinal} target={esExterno ? "_blank" : "_self"} 
         class="block w-full text-center bg-[#2563eb] text-white text-xs font-bold py-3 rounded-xl uppercase no-underline">
        {botonTexto || "ACCESO"}
      </a>
    </div>
  </div>
</div>