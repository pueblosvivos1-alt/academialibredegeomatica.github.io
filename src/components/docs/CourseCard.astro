---
const { entry } = Astro.props;

if (!entry || !entry.data) return null;

const { title, image, url_destino, botonTexto } = entry.data;

// --- CORRECCIÓN AQUÍ ---
// 1. Quitamos el .md si existiera
// 2. Si el ID termina en /index o es simplemente index, lo eliminamos para que la URL sea limpia
const urlInterna = `/docs/${entry.id
  .replace(/\.md$/, '')
  .replace(/\/index$/, '')
  .replace(/^index$/, '')}`;

const destinoFinal = url_destino || urlInterna;
const esExterno = String(destinoFinal).startsWith('http');
---

<div class="h-full bg-[#1e293b] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-xl transition-all hover:border-blue-500/50">
  
  <div class="relative aspect-video bg-slate-800 flex items-center justify-center p-2">
    {image ? (
      <img 
        src={image} 
        alt={title || "Miniatura del curso"} 
        class="w-full h-full object-contain"
        loading="lazy"
      />
    ) : (
      <div class="text-slate-500 text-xs italic">Sin previsualización</div>
    )}
  </div>

  <div class="p-5 flex flex-col flex-grow text-center">
    <h3 class="text-white font-bold text-sm mb-4 leading-tight min-h-[3rem] flex items-center justify-center">
      {title}
    </h3>

    <div class="mt-auto">
      <a 
        href={destinoFinal}
        target={esExterno ? "_blank" : "_self"}
        rel={esExterno ? "noopener noreferrer" : ""}
        class="block w-full text-center bg-[#2563eb] hover:bg-blue-500 text-white text-[10px] font-bold py-3 rounded-xl uppercase no-underline shadow-lg active:scale-95 transition-transform"
      >
        {url_destino ? "VER VIDEO" : (botonTexto || "ACCESO")}
      </a>
    </div>
  </div>
</div>