---
import { Image } from "astro:assets";

const { entry } = Astro.props;

// Extracción segura de datos
const title = entry.data?.title || "Sin título";
const image = entry.data?.image;
const empresa = entry.data?.empresa || "CAEG";
const tipo = entry.data?.tipo || "Curso corto";
const botonTexto = entry.data?.botonTexto || "ACCESO";

// Imprimimos para confirmar en terminal
console.log(`>>> PROCESANDO: ${title} | Imagen: ${typeof image}`);
---

<div class="h-full m-2 bg-[#0f172a] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl group">
  
  <div class="relative aspect-video bg-black overflow-hidden">
    {image ? (
      /* Si la imagen es un objeto procesable por Astro lo usamos, si es un string (SVG/Ruta) usamos <img> normal */
      typeof image === 'object' ? (
        <Image
          class="object-cover w-full h-full opacity-80 group-hover:scale-105 transition-transform duration-500"
          src={image}
          alt={title} 
          width={1280}
          height={720}
        />
      ) : (
        <img 
          src={image} 
          alt={title} 
          class="object-cover w-full h-full opacity-80" 
        />
      )
    ) : null}
    
    <div class="absolute top-2 right-2 z-10">
      <span class="bg-[#facc15] text-black text-[9px] font-black px-3 py-1 rounded-full uppercase shadow-xl">
        {tipo}
      </span>
    </div>
  </div>

  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-white font-bold text-sm mb-4 leading-tight">
      {title}
    </h3>

    <div class="mb-5 flex flex-col border-l-4 border-blue-600 bg-blue-900/30 p-3 rounded-r-lg">
      <span class="text-[8px] text-blue-400 font-black uppercase tracking-widest mb-1 text-center">Certifica:</span>
      <span class="text-white text-sm font-bold text-center">{empresa}</span>
    </div>

    <div class="mt-auto">
      <div class="w-full text-center bg-[#2563eb] text-white text-xs font-bold py-3 rounded-xl shadow-lg">
        {botonTexto}
      </div>
    </div>
  </div>
</div>

<style>
  .h-full { min-height: 400px; }
</style>