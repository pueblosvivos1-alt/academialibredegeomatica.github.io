---
const { entry } = Astro.props;
if (!entry || !entry.data) return null;

const { title, image, url_destino, botonTexto } = entry.data;

// Limpiamos la URL interna de cualquier .md
const urlInterna = `/docs/${entry.id.replace(/\.md$/, '')}`;
const destinoFinal = url_destino || urlInterna;
const esExterno = String(destinoFinal).startsWith('http');
---

<div class="h-full bg-[#1e293b] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-xl">
  <div class="relative aspect-video bg-slate-800 flex items-center justify-center p-2">
    {image ? (
      <img 
        src={image} 
        alt={title || "Imagen del curso"} 
        class="w-full h-full object-contain"
      />
    ) : (
      <div class="text-slate-500 text-xs italic">Sin imagen</div>
    )}
  </div>

  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-white font-bold text-sm mb-4 leading-tight">
      {title}
    </h3>

    <div class="mt-auto">
      <a 
        href={destinoFinal}
        target={esExterno ? "_blank" : "_self"}
        rel={esExterno ? "noopener noreferrer" : ""}
        class="block w-full text-center bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-bold py-3 rounded-xl uppercase no-underline transition-all"
      >
        {url_destino ? "VER VIDEO" : (botonTexto || "ACCESO")}
      </a>
    </div>
  </div>
</div>