---
const { entry } = Astro.props;
const { title, empresa, tipo, botonTexto, image } = entry.data;

// Esta línea extrae la ruta de la imagen sin importar si es un objeto o un string
const imgSrc = image?.src || image || "";
---

<div class="h-full m-2 bg-[#0f172a] border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl">
  <div class="relative aspect-video bg-black">
    {imgSrc && (
      <img 
        src={imgSrc} 
        alt={title} 
        class="object-cover w-full h-full opacity-80" 
      />
    )}
    <div class="absolute top-2 right-2">
      <span class="bg-yellow-400 text-black text-[10px] font-black px-2 py-1 rounded-full uppercase">
        {tipo || "Curso"}
      </span>
    </div>
  </div>

  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-white font-bold text-sm mb-4">{title}</h3>
    <div class="mb-5 border-l-4 border-blue-600 bg-blue-900/20 p-3">
      <p class="text-[8px] text-blue-400 font-bold uppercase">Certifica:</p>
      <p class="text-white text-sm font-bold">{empresa || "CAEG"}</p>
    </div>
    <div class="mt-auto w-full text-center bg-blue-600 text-white text-xs font-bold py-3 rounded-xl">
      {botonTexto || "ACCESO"}
    </div>
  </div>
</div>