---
import BaseLayout from "@components/base/BaseLayout.astro";
const { entry } = Astro.props;
if (!entry) return null;
const { title, image } = entry.data;
const { Content } = await entry.render();
---
<BaseLayout title={title}>
  <section class="py-16 bg-[#0f172a] min-h-screen">
    <div class="container mx-auto px-4 max-w-4xl text-white">
      <h1 class="text-3xl font-bold mb-8">{title}</h1>
      {image && <img src={image} alt={title} class="w-full h-auto rounded-2xl mb-8" />}
      <div class="prose prose-invert max-w-none"><Content /></div>
    </div>
  </section>
</BaseLayout>