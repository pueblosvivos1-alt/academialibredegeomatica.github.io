---
import BaseLayout from "@components/base/BaseLayout.astro";
import PageHeader from "@components/common/PageHeader.astro";
import type { DocsEntry } from "@/types";

interface Props {
  entry: DocsEntry;
}

const { entry } = Astro.props;

// Protección para evitar el error de "undefined" en localhost
if (!entry || !entry.data) {
  return Astro.redirect('/404');
}

const { title, description, image } = entry.data;
const { Content } = await entry.render();
---

<BaseLayout 
  title={title} 
  description={description} 
  image={image?.src || image}
>
  <PageHeader title={title} />
  
  <section class="section py-16 bg-[#0f172a]">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        
        {image && (
          <div class="mb-10">
            <img 
              src={image?.src || image} 
              alt={title} 
              class="w-full h-auto rounded-2xl shadow-2xl border border-slate-700"
            />
          </div>
        )}

        <div class="prose prose-invert prose-lg max-w-none 
                    prose-headings:text-white prose-p:text-slate-300 
                    prose-strong:text-emerald-400 prose-a:text-sky-400">
          <Content />
        </div>

      </div>
    </div>
  </section>
</BaseLayout>